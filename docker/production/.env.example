COMPOSE_PROJECT_NAME=jinhan-commerce-test
TZ=Asia/Shanghai

DEPLOY_HOME=/opt/jinhan/ai-commerce-test
CONFIG_REPO_HOME=/opt/jinhan/ai-commerce-test/config-repo
ADMIN_WEB_CONFIG_HOME=/opt/jinhan/ai-commerce-test/admin-web/config
ADMIN_WEB_DATA_HOME=/data/jinhan/ai-commerce-test/admin-web
ADMIN_WEB_LOG_HOME=/var/log/jinhan/ai-commerce-test/admin-web
STATIC_WEB_HOME=/opt/html/jinhan-shop-web-test

NGINX_HOME=/opt/docker/nginx
MYSQL_HOME=/opt/docker/mysql
REDIS_HOME=/opt/docker/redis
RABBITMQ_HOME=/opt/docker/rabbitmq

MYSQL_DATA_HOME=/data/docker/mysql
MYSQL_LOG_HOME=/opt/docker/mysql/logs
REDIS_DATA_HOME=/data/docker/redis
RABBITMQ_DATA_HOME=/data/docker/rabbitmq
RABBITMQ_LOG_HOME=/opt/docker/rabbitmq/logs
MINIO_DATA_HOME=/data/docker/minio

MYSQL_DATABASE=jinhan_shop
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_APP_USERNAME=jinhan_app
MYSQL_APP_PASSWORD=change-me-app-password
MYSQL_HOST_PORT=33306

# The following *_HOST values are Docker Compose service names used by
# application containers. Do not change them to the server public IP.
DB_HOST=mysql
DB_PORT=3306
DB_NAME=jinhan_shop
DB_URL=jdbc:mysql://mysql:3306/jinhan_shop?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=jinhan_app
DB_PASSWORD=change-me-app-password
DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_HOST_PORT=6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_AMQP_HOST_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USERNAME=jinhan
RABBITMQ_PASSWORD=change-me-rabbitmq-password
RABBITMQ_VHOST=/

MINIO_ROOT_USER=jinhan_minio
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

CONFIG_SERVER_USERNAME=config-server
CONFIG_SERVER_PASSWORD=change-me-config-server-password
CONFIG_SERVER_IMAGE=crpi-exofctq2c8bk7lmo.cn-guangzhou.personal.cr.aliyuncs.com/ze_yu/ze_yu1:config-server-test

ADMIN_WEB_IMAGE=crpi-exofctq2c8bk7lmo.cn-guangzhou.personal.cr.aliyuncs.com/ze_yu/ze_yu1:admin-web-test
ADMIN_WEB_HOST_PORT=8081

# Browser MCP runs as an independent service and is disabled until its Streamable HTTP endpoint is configured.
AI_CHAT_BROWSER_MCP_ENABLED=false
AI_CHAT_BROWSER_MCP_ENDPOINT=
AI_CHAT_BROWSER_MCP_BEARER_TOKEN=
AI_CHAT_BROWSER_MCP_TIMEOUT_MILLIS=60000
AI_CHAT_BROWSER_MCP_MAX_TOOL_ROUND_TRIPS=12

SPRING_CLOUD_CONFIG_PROFILE=test
SPRING_CLOUD_CONFIG_LABEL=main
SPRING_CLOUD_CONFIG_FAIL_FAST=true

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

IMAGE_REPOSITORY=crpi-exofctq2c8bk7lmo.cn-guangzhou.personal.cr.aliyuncs.com/ze_yu/ze_yu1
IMAGE_VERSION=test
BUILD_PLATFORM=linux/amd64
PUBLISH_MODE=buildx-push
RUNTIME_BASE_IMAGE=eclipse-temurin:17-jre-noble

REGISTRY_USERNAME=
REGISTRY_PASSWORD=

CONFIG_SERVER_IMAGE_OVERRIDE=
ADMIN_WEB_IMAGE_OVERRIDE=
