<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jinHan.shop.core.product.domain.mapper.ProductSpuMapper">
    <resultMap id="ProductSpuPageQueryResultMap" type="com.jinHan.shop.core.product.domain.model.ProductSpuPageQueryResult">
        <id column="id" property="id"/>
        <result column="supplier_id" property="supplierId"/>
        <result column="spu_code" property="spuCode"/>
        <result column="name" property="name"/>
        <result column="sub_title" property="subTitle"/>
        <result column="category_id" property="categoryId"/>
        <result column="brand_id" property="brandId"/>
        <result column="sale_status" property="saleStatus"/>
        <result column="audit_status" property="auditStatus"/>
        <result column="sort" property="sort"/>
        <result column="sales_count" property="salesCount"/>
        <result column="deleted" property="deleted"/>
        <result column="created_by" property="createdBy"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_time" property="updatedTime"/>
        <result column="supplier_name" property="supplierName"/>
        <result column="category_name" property="categoryName"/>
        <result column="brand_name" property="brandName"/>
    </resultMap>

    <select id="selectPageWithName" resultMap="ProductSpuPageQueryResultMap">
        SELECT
            p.id,
            p.supplier_id,
            p.spu_code,
            p.name,
            p.sub_title,
            p.category_id,
            p.brand_id,
            p.sale_status,
            p.audit_status,
            p.sort,
            p.sales_count,
            p.deleted,
            p.created_by,
            p.updated_by,
            p.created_time,
            p.updated_time,
            s.supplier_name AS supplier_name,
            c.name AS category_name,
            b.name AS brand_name
        FROM product_spu p
            LEFT JOIN supplier s ON p.supplier_id = s.id
            LEFT JOIN goods_category c ON p.category_id = c.id
            LEFT JOIN goods_brand b ON p.brand_id = b.id
        WHERE p.deleted = 0
        <if test="command.name != null and command.name != ''">
            AND p.name LIKE CONCAT('%', #{command.name}, '%')
        </if>
        <if test="command.spuCode != null and command.spuCode != ''">
            AND p.spu_code LIKE CONCAT('%', #{command.spuCode}, '%')
        </if>
        <if test="command.supplierId != null">
            AND p.supplier_id = #{command.supplierId}
        </if>
        <if test="command.categoryId != null">
            AND p.category_id = #{command.categoryId}
        </if>
        <if test="command.brandId != null">
            AND p.brand_id = #{command.brandId}
        </if>
        <if test="command.saleStatus != null">
            AND p.sale_status = #{command.saleStatus.code}
        </if>
        <if test="command.auditStatus != null">
            AND p.audit_status = #{command.auditStatus.code}
        </if>
        ORDER BY p.sort ASC, p.created_time DESC
    </select>
</mapper>
